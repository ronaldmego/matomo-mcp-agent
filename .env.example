# Matomo instance URL (required)
MATOMO_URL=https://your-matomo-instance.com

# Matomo API token — generate at Settings → Personal → Security (required)
MATOMO_TOKEN=your_matomo_api_token

# Default site ID in your Matomo instance (default: 1)
DEFAULT_SITE_ID=1

# Site aliases for natural language resolution (optional)
# Format: alias1:id1,alias2:id2
# MATOMO_SITES=my-site:1,blog:2

# Google Gemini API key — get at https://aistudio.google.com/apikey (required)
GOOGLE_API_KEY=your_google_gemini_api_key
